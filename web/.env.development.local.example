# Optional local overrides for frontend development.
#
# Usage:
# 1. Copy this file to `.env.development.local`
# 2. Keep the proxy target variables commented out if you use the SSH tunnel workflow
# 3. Uncomment the proxy target variables if you want Vite to talk to a remote RAGFlow backend directly

PORT=9222
VITE_BASE_URL='/'

# -----------------------------------------------------------------------------
# Option 1: SSH tunnel (recommended default)
# -----------------------------------------------------------------------------
# Leave the proxy target variables below commented out.
#
# Example PowerShell command:
# ssh -N -L 9380:127.0.0.1:9380 -L 9381:127.0.0.1:9381 your_user@192.168.131.245

# -----------------------------------------------------------------------------
# Option 2: Direct remote proxy (no SSH tunnel)
# -----------------------------------------------------------------------------
# Uncomment and adjust these values if you want Vite to proxy API requests
# directly to a remote RAGFlow server.

# VITE_API_PROXY_TARGET='http://192.168.131.245:9380'
# VITE_ADMIN_PROXY_TARGET='http://192.168.131.245:9381'

